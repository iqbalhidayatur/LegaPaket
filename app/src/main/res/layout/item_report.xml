<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/rounded_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:elevation="2dp">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvResi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LP-123456"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="22 Mei 2026"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Processing"
            android:textStyle="bold"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"/>

    </LinearLayout>

    <!-- DETAIL -->
    <LinearLayout
        android:id="@+id/ll_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:background="#E0E0E0"/>

        <TextView
            android:id="@+id/tv_receiver_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Penerima: Budi"
            android:textSize="13sp"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_city_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Kota: Jakarta"
            android:textSize="13sp"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_type_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Tipe: Express"
            android:textSize="13sp"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_weight_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Berat: 2 Kg"
            android:textSize="13sp"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_price_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Ongkir: Rp 25.000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <!-- PAYMENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_payment_icon_detail"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_qris"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tv_payment_method"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="QRIS"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

        </LinearLayout>

        <!-- ACTION BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Edit"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="@color/text_primary"/>

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Delete"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#E53935"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>